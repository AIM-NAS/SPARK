        # Ensures identity mapping at init and clean gradient flow
        self.block1 = nn.Sequential(
            nn.BatchNorm1d(input_dim),
            nn.ReLU(),
            nn.Linear(input_dim, hidden_dim),
            nn.Dropout(dropout),
            nn.BatchNorm1d(hidden_dim),
            nn.ReLU(),
            nn.Linear(hidden_dim, hidden_dim),
        )
        
        # Unified batch normalization after residual addition — consistent, batch-aware,
        # and stable for sparse 20NG features (replaces LayerNorm + inconsistent BN usage)
        self.post_residual_bn = nn.BatchNorm1d(hidden_dim)
        
        # Classifier with post-BN ReLU (Linear → BN → ReLU → Dropout → Linear)
        # Eliminates ambiguous pre-activation ordering; uses fixed bottleneck_dim = 64
        # for stability and simplicity (avoids hidden_dim//4 edge cases and keeps params low)
        bottleneck_dim = 64
        self.classifier = nn.Sequential(
            nn.Linear(hidden_dim, bottleneck_dim),
            nn.BatchNorm1d(bottleneck_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(bottleneck_dim, num_classes),
        )

    def forward(self, x):
        # Pre-activation residual path: BN → ReLU → Linear → Dropout → BN → ReLU → Linear
        h = self.block1[0](x)  # BN on input
        h = self.block1[1](h)  # ReLU
        h = self.block1[2](h)  # Linear: input_dim → hidden_dim
        h = self.block1[3](h)  # Dropout
        h = self.block1[4](h)  # BN on intermediate
        h = self.block1[5](h)  # ReLU
        h = self.block1[6](h)  # Linear: hidden_dim → hidden_dim (residual output)
        
        # Skip connection applied *after* full residual block — standard ResNet style
        skip_out = self.skip(x)
        h = h + skip_out
        
        # Unified batch norm — consistent, stable, shape-safe
        h = self.post_residual_bn(h)
        
        # Classifier head: post-BN ReLU pattern
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
