import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Input normalization: LayerNorm (batch-invariant, shape-safe, critical for BoW features)
        self.input_norm = nn.LayerNorm(input_dim)
        
        # Projection from input to residual block dim (input_dim → hidden_dim)
        self.input_proj = nn.Linear(input_dim, hidden_dim)
        
        # Skip connection: identity projection only if dims match; otherwise learned linear
        # Now applied *after* input_norm — ensures skip carries normalized semantics
        if input_dim == hidden_dim:
            self.skip = nn.Identity()
        else:
            self.skip = nn.Linear(input_dim, hidden_dim, bias=False)
            nn.init.eye_(self.skip.weight)
        
        # Pre-activation residual block: now *without* internal LayerNorm on input;
        # instead, normalization happens *before* block entry in forward()
        # Block: ReLU → Dropout → Linear → ReLU → Dropout → Linear
        self.res_block = nn.Sequential(
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(hidden_dim, hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(hidden_dim, hidden_dim),
        )
        
        # Classifier head: Dropout moved *after* final Linear to reduce variance on logits
        # and avoid premature feature suppression before classification
        self.classifier_norm = nn.LayerNorm(hidden_dim)
        self.classifier_relu = nn.ReLU()
        self.classifier_dropout = nn.Dropout(0.1)
        self.classifier_linear = nn.Linear(hidden_dim, num_classes)

    def forward(self, x):
        # Input normalization first
        x_norm = self.input_norm(x)
        
        # Project normalized input to hidden_dim
        h = self.input_proj(x_norm)
        
        # Skip connection applied to normalized input (x_norm), not raw x
        skip_out = self.skip(x_norm)
        
        # Pre-activate h before residual block: LayerNorm + block
        h = self.res_block(self.classifier_norm(h))
        
        # Stable residual update
        h = h + skip_out
        
        # Classifier: LayerNorm → ReLU → Dropout → Linear (dropout *after* Linear)
        h = self.classifier_norm(h)
        h = self.classifier_relu(h)
        h = self.classifier_dropout(h)
        logits = self.classifier_linear(h)
        return logits

# ===== END EVOLVE PGN REGION =====
