import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_proj = nn.Linear(input_dim, hidden_dim)
        self.activation = nn.ReLU()
        self.dropout = nn.Dropout(dropout)
        self.fc2 = nn.Linear(hidden_dim, hidden_dim)
        self.ln = nn.LayerNorm(hidden_dim)
        # Compact bottleneck classifier: reduces params and adds regularization
        self.classifier = nn.Sequential(
            nn.Linear(hidden_dim, 64),
            nn.ReLU(),
            nn.Dropout(0.1),
            nn.Linear(64, num_classes)
        )
        
        # Residual connection: project input *before* activation to match full first-block transform
        self.residual_proj = nn.Linear(input_dim, hidden_dim)

    def forward(self, x):
        # First layer: project, then apply residual *before* nonlinearity (pre-activation residual)
        h = self.input_proj(x)
        residual = self.residual_proj(x)
        h = h + residual  # identity-scaled residual before activation
        
        # Now apply activation + dropout
        h = self.activation(h)
        h = self.dropout(h)
        
        # Second block: LayerNorm *before* activation (Pre-LN style), then activation + dropout
        h = self.ln(h)
        h = self.fc2(h)
        h = self.activation(h)
        h = self.dropout(h)
        
        # Classifier head (bottleneck)
        logits = self.classifier(h)
        
        return logits

# ===== END EVOLVE PGN REGION =====
```
