import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_proj = nn.Linear(input_dim, hidden_dim)
        self.activation = nn.ReLU()
        self.dropout = nn.Dropout(dropout)
        
        # Residual projection: always defined for consistent signal scaling
        self.residual_proj = nn.Linear(input_dim, hidden_dim) if input_dim != hidden_dim else nn.Identity()
        self.ln = nn.LayerNorm(hidden_dim)
        
        # Compact classifier head: single linear layer with norm and dropout before activation
        self.head_ln = nn.LayerNorm(hidden_dim)
        self.head_dropout = nn.Dropout(dropout)
        self.classifier = nn.Linear(hidden_dim, num_classes)

    def forward(self, x):
        # Project input
        h = self.input_proj(x)
        
        # Normalize → dropout → residual add → activate (pre-norm residual pattern)
        h = self.ln(h)
        h = self.dropout(h)
        residual = self.residual_proj(x)
        h = h + residual
        h = self.activation(h)
        
        # Compact head: norm → dropout → activate → classify
        h = self.head_ln(h)
        h = self.head_dropout(h)
        h = self.activation(h)
        logits = self.classifier(h)
        
        return logits

# ===== END EVOLVE PGN REGION =====
