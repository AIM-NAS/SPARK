        self.block1 = nn.Sequential(
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(input_dim, hidden_dim),
            nn.Linear(hidden_dim, hidden_dim),
        )
        
        # Stable post-residual normalization (no affine params, batch-size invariant)
        self.post_residual_norm = nn.LayerNorm(hidden_dim, elementwise_affine=False)
        
        # Compact two-layer classifier head: avoids bottleneck truncation,
        # removes conflicting BatchNorm, reuses LayerNorm stability + dropout regularization
        self.classifier = nn.Sequential(
            nn.Linear(hidden_dim, hidden_dim),
            nn.LayerNorm(hidden_dim, elementwise_affine=False),
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(hidden_dim, num_classes),
        )

    def forward(self, x):
        # Pre-activation residual: apply nonlinearity & dropout *before* first Linear
        h = self.block1[0](x)  # ReLU
        h = self.block1[1](h)  # Dropout
        h = self.block1[2](h)  # First Linear (input_dim → hidden_dim)
        h = self.block1[3](h)  # Second Linear (hidden_dim → hidden_dim)
        
        # Residual addition: skip(x) added *after* full block output (canonical pre-act)
        skip_out = self.skip(x)
        h = h + skip_out
        
        # Stable normalization
        h = self.post_residual_norm(h)
        
        # Classifier: no redundant BN; LayerNorm + Dropout ensures robustness
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
