        self.head_norm = nn.LayerNorm(hidden_dim)
        self.head = nn.Sequential(
            nn.Linear(hidden_dim, bottleneck_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(bottleneck_dim, num_classes),
        )

    def forward(self, x):
        # Pre-activation residual: normalize input, then apply residual and block
        norm_x = self.norm1(x)
        identity = self.residual(norm_x)
        out = self.block1(norm_x)
        out = out + identity  # residual addition *before* nonlinearity in next stage
        
        # Classifier head with stabilization
        out = self.head_norm(out)
        logits = self.head(out)
        return logits

# ===== END EVOLVE PGN REGION =====
