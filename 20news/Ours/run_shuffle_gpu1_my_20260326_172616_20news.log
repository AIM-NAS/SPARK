fication\n        bottleneck_dim = max(hidden_dim // 2, 64)\n        self.classifier = nn.Sequential(\n            nn.Linear(hidden_dim, bottleneck_dim),\n            nn.ReLU(),\n            nn.Linear(bottleneck_dim, num_classes, bias=True),\n        )\n\n    def forward(self, x):\n        # Compute skip path *before* normalization — preserves raw input magnitude for residual\n        skip_out = self.skip(x)\n        \n        # Normalize *only* for main branch input\n        x_norm = self.input_norm(x)\n        \n        # Main branch\n        h = self.block1(x_norm)\n        \n        # Residual block\n        h_res = self.res_block(h)\n        \n        # Shared gate: sigmoid applied to h (not concatenated), then elementwise scale\n        gate = torch.sigmoid(self.res_gate(h))  # (B, hidden_dim)\n        \n        # Pure residual update: no concatenation, no bias in gate, no double-normalization\n        h = gate * h_res + (1 - gate) * skip_out\n        \n        # Classifier: ReLU → Linear only — restores dynamic range and avoids rank collapse\n        logits = self.classifier(h)\n        return logits\n\n# ===== END EVOLVE PGN REGION =====\n'}
