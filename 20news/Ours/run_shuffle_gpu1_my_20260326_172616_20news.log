        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Input normalization: applied *after* skip computation — raw x used for skip path
        self.input_norm = nn.LayerNorm(input_dim)
        
        # Residual projection: projects raw input to hidden_dim — zero-initialized, bias-free
        self.skip = nn.Linear(input_dim, hidden_dim, bias=False)
        nn.init.zeros_(self.skip.weight)
        
        # Revised block1: now applied *after* input_norm — normalized features feed main branch
        self.block1 = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Gated residual sub-block: simplified to single shared Linear + sigmoid gate
        # Now gates on *transformed* h (block1 output), not raw h — stabilizes gate dynamics
        self.res_gate = nn.Linear(hidden_dim, hidden_dim)  # scalar gate per dim
        self.res_block = nn.Sequential(
            nn.Linear(hidden_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Classifier head: replaced bottleneck with direct projection + lightweight pre-logits dropout
        # Eliminates unnecessary compression and rank collapse; improves gradient flow
        self.classifier_dropout = nn.Dropout(dropout)
        self.classifier = nn.Linear(hidden_dim, num_classes, bias=True)

    def forward(self, x):
        # Compute skip path *before* normalization — preserves raw input magnitude for residual
        skip_out = self.skip(x)
        skip_out = torch.relu(skip_out)  # Activate skip path to ensure meaningful contribution at init
        
        # Normalize *only* for main branch input
        x_norm = self.input_norm(x)
        
        # Main branch
        h = self.block1(x_norm)
        
        # Residual block
        h_res = self.res_block(h)
        
        # Shared gate: sigmoid applied to *transformed* h (output of block1), not raw h
        # This aligns gating with the same feature space used in res_block — stable & shape-safe
        gate = torch.sigmoid(self.res_gate(h))  # (B, hidden_dim)
        
        # Pure residual update
