        self.input_norm = nn.LayerNorm(input_dim)
        
        # Pre-activation residual block: Linear → LayerNorm → ReLU → Dropout → Linear
        # Projects input_dim → hidden_dim, then applies normalized residual update
        self.res_block = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
