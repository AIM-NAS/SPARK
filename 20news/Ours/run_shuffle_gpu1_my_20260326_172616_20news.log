import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_proj = nn.Linear(input_dim, hidden_dim)
        self.activation = nn.ReLU()
        self.dropout = nn.Dropout(dropout)
        
        # Lightweight projection-aware residual: use linear skip when dims mismatch
        self.use_residual = True
        if input_dim == hidden_dim:
            self.res_proj = nn.Identity()
        else:
            self.res_proj = nn.Linear(input_dim, hidden_dim, bias=False)
            # Zero-initialize to preserve initial dynamics
            nn.init.zeros_(self.res_proj.weight)

        self.ln = nn.LayerNorm(hidden_dim)
        
        # Remove redundant head_ln and head_dropout; apply single dropout after activation
        self.classifier = nn.Linear(hidden_dim, num_classes)

    def forward(self, x):
        # Project input
        h = self.input_proj(x)
        
        # Residual addition with projection if needed (shape-safe)
        h = h + self.res_proj(x)
        
        # Pre-norm: LayerNorm → activation → dropout (standard stable order)
        h = self.ln(h)
        h = self.activation(h)
        h = self.dropout(h)
        
        # Direct classification (no extra norm/dropout — eliminates redundancy)
        logits = self.classifier(h)
        
        return logits

# ===== END EVOLVE PGN REGION =====
```
