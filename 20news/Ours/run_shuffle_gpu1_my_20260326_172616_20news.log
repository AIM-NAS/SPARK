import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # First block: input → hidden with norm + activation
        self.linear1 = nn.Linear(input_dim, hidden_dim)
        self.norm1 = nn.LayerNorm(hidden_dim)
        self.relu = nn.ReLU()
        
        # Residual connection: project input to hidden if dims mismatch
        if input_dim != hidden_dim:
            self.skip_proj = nn.Linear(input_dim, hidden_dim)
        else:
            self.skip_proj = None
        
        # Classifier head: single linear layer (hidden → num_classes)
        self.classifier = nn.Linear(hidden_dim, num_classes)
        
        # Shared dropout applied after residual addition
        self.dropout = nn.Dropout(dropout)

    def forward(self, x):
        # First MLP block: linear → norm → relu (no dropout yet)
        h = self.linear1(x)
        h = self.norm1(h)
        h = self.relu(h)
        
        # Add skip connection with proper dimension alignment
        if self.skip_proj is not None:
            skip = self.skip_proj(x)
        else:
            skip = x
        h = h + skip  # residual connection
        
        # Apply dropout to the full residual output
        h = self.dropout(h)
        
        # Classifier head
        logits = self.classifier(h)
        
        return logits

# ===== END EVOLVE PGN REGION =====
```
