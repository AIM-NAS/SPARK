        # Residual connection: skip path applied *after* first nonlinearity
        skip_out = self.skip(x)
        h = h + skip_out
        
        # Stable post-residual normalization
        h = self.post_residual_norm(h)
        
        # Classifier head with BN only on full hidden_dim input
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
