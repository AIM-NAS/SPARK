import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=128, dropout=0.2):
        super().__init__()
        self.input_proj = nn.Linear(input_dim, hidden_dim)
        self.norm1 = nn.LayerNorm(hidden_dim)
        # Bottleneck MLP: improves expressivity & regularization while preserving width
        self.hidden_proj = nn.Sequential(
            nn.Linear(hidden_dim, hidden_dim // 2),
            nn.ReLU(),
            nn.Linear(hidden_dim // 2, hidden_dim)
        )
        self.norm2 = nn.LayerNorm(hidden_dim)
        self.dropout = nn.Dropout(dropout)
        self.classifier = nn.Linear(hidden_dim, num_classes)
        self.activation = nn.ReLU()
        
        # Explicit bias initialization for calibrated logits (improves imbalance robustness)
        nn.init.constant_(self.classifier.bias, 0)

    def forward(self, x):
        # First projection + norm + activation (post-norm)
        h = self.input_proj(x)
        h = self.norm1(h)
        h = self.activation(h)
        
        # Residual block: norm → act → transform → dropout → residual (pre-norm style)
        h_residual = h
        h = self.norm2(h)
        h = self.activation(h)
        h = self.hidden_proj(h)
        h = self.dropout(h)
        h = h + h_residual  # Post-activation residual (stable identity mapping)
        
        # Classifier head
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
```
