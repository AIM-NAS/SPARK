import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Learnable affine projection for residual path — enables safe identity initialization
        # even when input_dim != hidden_dim (zero-init bias ensures identity at start)
        self.skip = nn.Linear(input_dim, hidden_dim, bias=True)
        with torch.no_grad():
            self.skip.weight.copy_(torch.zeros_like(self.skip.weight))
            if self.skip.bias is not None:
                self.skip.bias.zero_()
            # Set diagonal of weight to 1.0 *only* where possible (for approximate identity init)
            if input_dim == hidden_dim:
                self.skip.weight.copy_(torch.eye(hidden_dim))
            elif input_dim < hidden_dim:
                self.skip.weight[:input_dim, :input_dim] = torch.eye(input_dim)

        # Residual block: simplified — no internal LayerNorm (moved to post-residual only)
        self.block1 = nn.Sequential(
            nn.Linear(hidden_dim, hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Single, clean LayerNorm after residual addition — per-sample stable, no redundancy
        self.post_residual_norm = nn.LayerNorm(hidden_dim, elementwise_affine=True)
        
        # Classifier head regularization: add dropout before final linear layer
        self.classifier_dropout = nn.Dropout(0.1)
        self.classifier = nn.Linear(hidden_dim, num_classes)

    def forward(self, x):
        # Project input to hidden_dim via learnable skip (identity-initialized)
        h = self.skip(x)
        # Apply residual transformation: h = h + block1(h)
        h = h + self.block1(h)
        # Normalize once after residual
        h = self.post_residual_norm(h)
        # Regularize classifier input
        h = self.classifier_dropout(h)
        # Final classification
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
```
