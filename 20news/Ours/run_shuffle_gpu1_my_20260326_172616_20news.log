        # Preserves output shape (B, num_classes) and interface compatibility
        self.classifier = nn.utils.weight_norm(
            nn.Linear(hidden_dim, num_classes, bias=False), 
            dim=0
        )

    def forward(self, x):
        # Apply deeper block
        h = self.block1(x)
        # Compute skip path and scale it
        skip_out = self.skip(x)
        skip_out = self.gamma * skip_out
        # Residual connection: sum first, then normalize
        h = h + skip_out
        h = self.post_residual_norm(h)
        # Apply weight-normalized classifier head
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
