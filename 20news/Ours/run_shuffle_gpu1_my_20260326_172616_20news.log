import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Input normalization: LayerNorm (batch-invariant, shape-safe, critical for BoW features)
        self.input_norm = nn.LayerNorm(input_dim)
        
        # Revised block1: now includes learned projection + gated residual in one coherent path
        # Eliminates standalone skip module — projection is fused into first Linear
        self.block1 = nn.Sequential(
            nn.LayerNorm(input_dim),
            nn.Linear(input_dim, hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Residual block: pre-norm → Linear → ReLU → Dropout → LayerNorm (stabilizes residual accumulation)
        self.res_block = nn.Sequential(
            nn.LayerNorm(hidden_dim),
            nn.Linear(hidden_dim, hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.LayerNorm(hidden_dim),  # final norm stabilizes variance before residual addition
        )
        
        # Learnable scalar gate for residual update: initialized near 0 for stable training
        self.gate = nn.Parameter(torch.tensor(0.0))
        
        # Classifier head: simplified to single linear layer with dropout only before it
        # Aligns with BoW's linear separability bias and reduces over-parameterization
        self.classifier = nn.Sequential(
            nn.Dropout(dropout),
            nn.Linear(hidden_dim, num_classes, bias=True),
        )

    def forward(self, x):
        # Input normalization first
        x = self.input_norm(x)
        
        # Main branch: block1 produces h of shape (B, hidden_dim)
        h = self.block1(x)
        
        # Apply residual sub-block (now includes final LayerNorm)
        h = self.res_block(h)
        
        # Scalar-gated residual update: h = h + gate * x_projected
        # Project x directly inside forward — no separate skip module, reusing block1's weight logic
        # This avoids redundant projection while preserving gated residual semantics
        x_proj = nn.functional.linear(x, self.block1[1].weight, self.block1[1].bias)
        h = h + torch.sigmoid(self.gate) * x_proj
        
        # Classifier
        logits = self.classifier(h)
        return logits

