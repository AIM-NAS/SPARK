                nn.Linear(input_dim, hidden_dim),
                nn.BatchNorm1d(hidden_dim)
            )
        
        # Compact, stabilized classifier head: LayerNorm + single linear layer
        self.classifier = nn.Sequential(
            nn.LayerNorm(hidden_dim),
            nn.Linear(hidden_dim, num_classes),
        )

    def forward(self, x):
        # Apply first block
        h = self.block1(x)
        # Add residual connection (now both paths are batch-normalized)
        h = h + self.skip(x)
        # Apply compact classifier head
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
