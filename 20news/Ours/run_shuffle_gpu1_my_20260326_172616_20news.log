import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_proj = nn.Linear(input_dim, hidden_dim)
        self.activation = nn.ReLU()
        self.dropout = nn.Dropout(dropout)
        self.fc2 = nn.Linear(hidden_dim, hidden_dim)
        # Pre-activation LayerNorm before fc2 (standard stable pattern)
        self.ln = nn.LayerNorm(hidden_dim)
        # Single linear classifier head — full rank, no artificial bottleneck
        self.classifier = nn.Linear(hidden_dim, num_classes)
        
        # Lightweight skip: only project if dims differ; identity otherwise
        self.skip_proj = nn.Linear(input_dim, hidden_dim) if input_dim != hidden_dim else None

    def forward(self, x):
        # First block: pre-activation residual (project then add before activation)
        h = self.input_proj(x)
        if self.skip_proj is not None:
            residual = self.skip_proj(x)
        else:
            residual = x if x.shape[-1] == h.shape[-1] else self.input_proj(x)  # fallback safety
        h = h + residual
        h = self.activation(h)
        h = self.dropout(h)
        
        # Second block: pre-activation norm → linear → activation → dropout
        h_norm = self.ln(h)
        h = self.fc2(h_norm)
        h = self.activation(h)
        h = self.dropout(h)
        
        # Classifier: single linear + no dropout in head (logits are unnormalized; dropout harms calibration)
        logits = self.classifier(h)
        
        return logits

# ===== END EVOLVE PGN REGION =====
```
