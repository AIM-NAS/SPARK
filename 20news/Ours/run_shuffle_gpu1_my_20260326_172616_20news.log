import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Pre-residual projection with nonlinearity: learnable alignment + ReLU
        # Enables adaptive dimension matching *and* introduces early nonlinearity
        # for sparse/low-SNR inputs (e.g., TF-IDF), improving gradient flow symmetry.
        self.skip = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.ReLU()
        ) if input_dim != hidden_dim else nn.Identity()
        
        # Residual block retains internal LayerNorm + ReLU + Dropout — stable and expressive
        self.block1 = nn.Sequential(
            nn.Linear(hidden_dim, hidden_dim),
            nn.LayerNorm(hidden_dim, elementwise_affine=True),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Removed post_residual_norm per LLM2 feedback: eliminates double normalization,
        # reduces latency/params, and improves trainability without harming stability.
        
        # Adaptive channel scaling remains for lightweight feature modulation
        self.channel_scale = nn.Parameter(torch.ones(hidden_dim))
        
        # Classifier head now includes final dropout for boundary regularization
        # Shape-safe: applied just before classifier, preserves (B, num_classes) output
        self.classifier_dropout = nn.Dropout(dropout)
        self.classifier = nn.Linear(hidden_dim, num_classes)

    def forward(self, x):
        # Pre-residual path: nonlinear projection (if needed) + ReLU
        h_skip = self.skip(x)
        
        # Transformative residual path: block1 operates on h_skip (same shape)
        h = self.block1(h_skip)
        
        # Residual addition: h_skip already matches hidden_dim and is nonlinear
        h = h_skip + h
        
        # Apply adaptive scaling
        h = h * self.channel_scale
        
        # Regularize before final classification
        h = self.classifier_dropout(h)
        
        # Final logits
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
