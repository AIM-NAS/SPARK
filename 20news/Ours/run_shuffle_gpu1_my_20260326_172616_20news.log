        self.bottleneck_activation = nn.GELU()
        self.classifier = nn.Linear(bottleneck_dim, num_classes)

    def forward(self, x):
        # Project input
        h = self.input_proj(x)
        
        # Normalize → dropout → residual add → activate (aligned residual per LLM2)
        h = self.ln(h)
        h = self.dropout(h)
        residual = self.residual_proj(x)
        h = h + residual
        h = self.activation(h)
        
        # Bottleneck head: project → activate → classify
        h = self.bottleneck(h)
        h = self.bottleneck_activation(h)
        logits = self.classifier(h)
        
        return logits

# ===== END EVOLVE PGN REGION =====
