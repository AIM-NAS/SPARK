import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=128, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # First block: Linear → LayerNorm → ReLU → Dropout (moved Dropout after ReLU)
        self.block1 = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Learnable residual projection: always enabled, shape-safe
        self.residual_proj = nn.Linear(input_dim, hidden_dim) if input_dim != hidden_dim else None
        
        # Two-layer classifier head with normalization and improved capacity
        self.classifier = nn.Sequential(
            nn.Linear(hidden_dim, 64),
            nn.LayerNorm(64),
            nn.ReLU(),
            nn.Dropout(0.1),
            nn.Linear(64, num_classes),
        )

    def forward(self, x):
        # Apply first block
        h = self.block1(x)
        
        # Add residual connection: use projection if dims mismatch, identity otherwise
        if self.residual_proj is not None:
            h = h + self.residual_proj(x)
        else:
            h = h + x
        
        # Apply enhanced classifier
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
```
