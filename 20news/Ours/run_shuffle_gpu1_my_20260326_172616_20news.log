import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Input normalization: LayerNorm (batch-invariant, shape-safe, critical for BoW features)
        self.input_norm = nn.LayerNorm(input_dim)
        
        # Residual projection: projects input to hidden_dim
        self.skip = nn.Linear(input_dim, hidden_dim, bias=False)
        nn.init.zeros_(self.skip.weight)
        
        # Unified residual block with pre-activation design
        # Block: LayerNorm → Linear → ReLU → Dropout → (residual add)
        self.block1 = nn.Sequential(
            nn.LayerNorm(input_dim),
            nn.Linear(input_dim, hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        self.res_block = nn.Sequential(
            nn.LayerNorm(hidden_dim),
            nn.Linear(hidden_dim, hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Learned affine residual scale: replaces sigmoid(gate) with trainable linear + bias
        # Shape: (B, 1) → broadcastable to (B, hidden_dim); initialized near identity (scale=1, bias=0)
        self.rescale = nn.Linear(1, 1, bias=True)
        with torch.no_grad():
            self.rescale.weight.fill_(1.0)
            self.rescale.bias.zero_()
        
        # Simplified classifier head: LayerNorm → Dropout → Linear
        # Removes redundant hidden_dim→hidden_dim bottleneck while preserving regularization
        self.classifier = nn.Sequential(
            nn.LayerNorm(hidden_dim),
            nn.Dropout(dropout),
            nn.Linear(hidden_dim, num_classes, bias=True),
        )

    def forward(self, x):
        # Input normalization first
        x = self.input_norm(x)
        
        # Pre-activation residual: compute skip *before* block1
        skip_out = self.skip(x)
        
        # Main branch
        h = self.block1(x)
        
        # Apply residual sub-block
        h = self.res_block(h)
        
        # Affine-gated residual update: h = h + rescale(1) * skip_out
        # rescale(torch.ones_like(h[:, :1])) gives (B, 1) → broadcasted to (B, hidden_dim)
        scale = self.rescale(torch.ones_like(h[:, :1]))
        h = h + scale * skip_out
        
        # Classifier
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
