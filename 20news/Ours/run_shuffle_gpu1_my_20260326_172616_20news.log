        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # First block: normalize before nonlinearity for stable residual
        self.block1 = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.BatchNorm1d(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Second lightweight block for hierarchical feature refinement
        self.block2 = nn.Sequential(
            nn.Linear(hidden_dim, hidden_dim),
            nn.BatchNorm1d(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Normalized skip connection: project input to hidden_dim with batch norm alignment
        if input_dim == hidden_dim:
            self.skip = nn.Sequential(
                nn.BatchNorm1d(hidden_dim),
                nn.Identity()
            )
        else:
            self.skip = nn.Sequential(
                nn.Linear(input_dim, hidden_dim),
                nn.BatchNorm1d(hidden_dim)
            )
        
        # Simplified classifier head: remove redundant LayerNorm after batch-normalized residual
        self.classifier = nn.Linear(hidden_dim, num_classes)

    def forward(self, x):
        # Apply first block
        h = self.block1(x)
        # Add residual connection
        h = h + self.skip(x)
        # Apply second block for deeper transformation
