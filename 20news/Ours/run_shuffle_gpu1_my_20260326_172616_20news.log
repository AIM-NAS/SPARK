        # Keeps skip path unnormalized (preserves BoW magnitude semantics), main branch normalized
        self.input_norm = nn.LayerNorm(input_dim)
        
        # Residual projection: projects raw input to hidden_dim — zero-initialized, bias-free
        self.skip = nn.Linear(input_dim, hidden_dim, bias=False)
        nn.init.zeros_(self.skip.weight)
        
        # Revised block1: now applied *after* input_norm — normalized features feed main branch
        self.block1 = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Gated residual sub-block: simplified to single shared Linear + sigmoid gate
        # Eliminates concatenation and unstable high-capacity gate; uses h only for gating
        self.res_gate = nn.Linear(hidden_dim, hidden_dim)  # scalar gate per dim
        self.res_block = nn.Sequential(
            nn.Linear(hidden_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Classifier head: expanded bottleneck with min-width safety and removed redundant LayerNorm
        # bottleneck_dim = max(hidden_dim // 2, 64) ensures sufficient capacity for 20-way classification
        bottleneck_dim = max(hidden_dim // 2, 64)
        self.classifier = nn.Sequential(
            nn.Linear(hidden_dim, bottleneck_dim),
            nn.ReLU(),
            nn.Linear(bottleneck_dim, num_classes, bias=True),
        )

    def forward(self, x):
        # Compute skip path *before* normalization — preserves raw input magnitude for residual
        skip_out = self.skip(x)
        
        # Normalize *only* for main branch input
        x_norm = self.input_norm(x)
        
        # Main branch
        h = self.block1(x_norm)
        
        # Residual block
        h_res = self.res_block(h)
        
        # Shared gate: sigmoid applied to h (not concatenated), then elementwise scale
        gate = torch.sigmoid(self.res_gate(h))  # (B, hidden_dim)
        
        # Pure residual update: no concatenation, no bias in gate, no double-normalization
        h = gate * h_res + (1 - gate) * skip_out
        
        # Classifier: ReLU → Linear only — restores dynamic range and avoids rank collapse
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
