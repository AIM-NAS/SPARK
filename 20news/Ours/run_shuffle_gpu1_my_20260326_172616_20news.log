        # and move it *before* the bottleneck linear (i.e., after residual, before activation)
        bottleneck_dim = hidden_dim // 4
        self.classifier = nn.Sequential(
            nn.BatchNorm1d(hidden_dim),  # ✅ Pre-activation BN on residual output
            nn.Linear(hidden_dim, bottleneck_dim),
            nn.ReLU(),
            nn.Dropout(0.1),
            nn.Linear(bottleneck_dim, num_classes),
