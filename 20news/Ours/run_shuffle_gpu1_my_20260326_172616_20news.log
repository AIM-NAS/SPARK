            nn.Linear(hidden_dim, bottleneck_dim),
            nn.ReLU(),
            nn.Dropout(0.1),
            nn.Linear(bottleneck_dim, num_classes),
        )

    def forward(self, x):
        # Apply pre-activation residual block: skip connects *after* first nonlinearity
        h = self.block1[0](x)  # First Linear
        h = self.block1[1](h)  # BN
        h = self.block1[2](h)  # ReLU
        h = self.block1[3](h)  # Dropout
