        self.block1 = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Gated residual sub-block: simplified to single shared Linear + sigmoid gate
        # Eliminates concatenation and unstable high-capacity gate; uses h only for gating
        self.res_gate = nn.Linear(hidden_dim, hidden_dim)  # scalar gate per dim
        self.res_block = nn.Sequential(
            nn.Linear(hidden_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Classifier head: expanded bottleneck with min-width safety and removed redundant LayerNorm
        # bottleneck_dim = max(hidden_dim // 2, 64) ensures sufficient capacity for 20-way classification
        bottleneck_dim = max(hidden_dim // 2, 64)
        self.classifier = nn.Sequential(
            nn.Linear(hidden_dim, bottleneck_dim),
            nn.ReLU(),
            nn.Linear(bottleneck_dim, num_classes, bias=True),
        )

    def forward(self, x):
