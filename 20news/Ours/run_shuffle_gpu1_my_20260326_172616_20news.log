        # Replaces brittle Identity + implicit assumption; enables stable gradient flow
        self.skip = nn.Identity() if input_dim == hidden_dim else nn.Linear(input_dim, hidden_dim, bias=False)
        if input_dim != hidden_dim:
            nn.init.orthogonal_(self.skip.weight)

        # Residual MLP sub-block: pre-activation order (LayerNorm → ReLU → Dropout → Linear)
