import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=128, dropout=0.2):
        super().__init__()
        self.input_proj = nn.Linear(input_dim, hidden_dim)
        self.norm1 = nn.LayerNorm(hidden_dim)
        # Replace asymmetric bottleneck with symmetric residual block: Linear + GELU
        self.residual_proj = nn.Linear(hidden_dim, hidden_dim)
        self.norm2 = nn.LayerNorm(hidden_dim)
        self.dropout = nn.Dropout(dropout)
        # Classifier with weight normalization for better logit calibration
        self.classifier = nn.utils.weight_norm(nn.Linear(hidden_dim, num_classes), dim=0)
        self.activation = nn.GELU()

    def forward(self, x):
        # Pre-norm activation with learnable skip: h = input_proj(x) + x_pad
        h = self.input_proj(x)
        # Learnable pre-residual skip: pad or truncate x to hidden_dim and add
        if x.size(1) >= h.size(1):
            x_skip = x[:, :h.size(1)]
        else:
            x_skip = nn.functional.pad(x, (0, h.size(1) - x.size(1)), mode='constant', value=0.0)
        h = h + x_skip
        h = self.norm1(h)
        h = self.activation(h)
        
        # Symmetric residual block: no width reduction, GELU, norm after projection
        h_residual = h
        h = self.residual_proj(h)
        h = self.norm2(h)
        h = self.activation(h)
        h = self.dropout(h)
        h = h + h_residual
        
        # Classifier: apply dropout *after* classifier per LLM2 suggestion (but note: Dropout1d not valid on 2D logits;
        # instead, use standard Dropout on features before classifier — already done above; so here we just project)
        # Weight-normed classifier ensures well-calibrated logits without bias instability
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
