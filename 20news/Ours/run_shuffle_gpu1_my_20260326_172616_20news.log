import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Residual projection: zero-initialized linear for safe identity-by-default coupling
        # Avoids redundant projection and aligns skip path with block1's output space
        self.skip = nn.Linear(input_dim, hidden_dim) if input_dim != hidden_dim else nn.Identity()
        if input_dim != hidden_dim:
            nn.init.zeros_(self.skip.weight)
            if self.skip.bias is not None:
                nn.init.zeros_(self.skip.bias)
        
        # Block1: now starts with input→hidden_dim projection *inside* the block,
        # with BN → ReLU → Dropout applied consistently before residual addition.
        # Removed redundant initial projection outside — block handles its own input alignment.
        self.block1 = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.BatchNorm1d(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(hidden_dim, hidden_dim),
            nn.BatchNorm1d(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Removed post_residual_norm: normalization now happens *within* block1,
        # and residual addition occurs in normalized+activated space — cleaner, more stable.
        
        # Simplified classifier head: single stabilized linear layer
        # Reduces parameters and avoids over-parameterization for 20-class task
        self.classifier_norm = nn.BatchNorm1d(hidden_dim)
        self.classifier_dropout = nn.Dropout(0.1)
        self.classifier = nn.Linear(hidden_dim, num_classes)

    def forward(self, x):
        # Apply block1 to get main path
        h = self.block1(x)
        # Skip connection: zero-initialized projection (identity-by-default)
        skip_out = self.skip(x)
        # Residual addition in normalized+activated space (stable)
        h = h + skip_out
        # Classifier: normalize → dropout → linear
        h = self.classifier_norm(h)
        h = self.classifier_dropout(h)
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
```
