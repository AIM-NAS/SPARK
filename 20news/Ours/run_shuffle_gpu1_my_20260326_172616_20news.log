import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Input normalization: LayerNorm (batch-invariant, shape-safe, critical for BoW features)
        self.input_norm = nn.LayerNorm(input_dim)
        
        # Residual projection: pre-activation skip path — projects input to hidden_dim *before* block1
        # Zero-initialized for stable residual learning; bias=False ensures clean zero-init
        self.skip = nn.Linear(input_dim, hidden_dim, bias=False)
        nn.init.zeros_(self.skip.weight)
        
        # Revised block1: single Linear → LayerNorm → ReLU → Dropout
        # Replaced BatchNorm1d with LayerNorm per LLM2 feedback for batch-invariant stability on sparse BoW
        self.block1 = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Gated residual sub-block: Linear → LayerNorm → ReLU → Dropout → gate projection
        # Projects to hidden_dim*2 for sigmoid gating before addition (shape-safe, no parameter increase)
        self.res_block = nn.Sequential(
            nn.Linear(hidden_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        self.gate_proj = nn.Linear(hidden_dim, hidden_dim * 2)  # for gating: h, g = gate_proj(out).chunk(2)
        
        # Classifier head: expanded bottleneck to hidden_dim // 2 and added learnable bias to final layer
        # Removed dropout from bottleneck (harmful rank collapse); retained LayerNorm for stability
        bottleneck_dim = hidden_dim // 2
        self.classifier = nn.Sequential(
            nn.Linear(hidden_dim, bottleneck_dim),
            nn.LayerNorm(bottleneck_dim),
            nn.ReLU(),
            nn.Linear(bottleneck_dim, num_classes, bias=True),  # explicit bias=True for expressivity
        )

    def forward(self, x):
        # Input normalization first
        x = self.input_norm(x)
        
        # Pre-activation residual: compute skip *before* block1
        skip_out = self.skip(x)
        
        # Main branch
        h = self.block1(x)
        
        # Apply residual sub-block
        h = self.res_block(h)
        
        # Gated residual update: h = h * sigmoid(g) + skip_out * sigmoid(1-g)
        # Compute gate: [h_gate, skip_gate] = sigmoid(gate_proj(h))
        gate_input = self.gate_proj(h)  # (B, 2*hidden_dim)
        h_gate, skip_gate = gate_input.chunk(2, dim=-1)
        h_gate = torch.sigmoid(h_gate)
        skip_gate = torch.sigmoid(skip_gate)
        h = h * h_gate + skip_out * skip_gate
        
        # Classifier
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
