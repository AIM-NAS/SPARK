        self.skip = nn.Identity() if input_dim == hidden_dim else nn.Linear(input_dim, hidden_dim)
        
        # Pre-activation residual block: ReLU & Dropout *before* first Linear,
        # then Linear → Linear, with skip added *after* the sum (true pre-act)
        # Fixes brittle alignment: skip now connects x directly, and nonlinearity
