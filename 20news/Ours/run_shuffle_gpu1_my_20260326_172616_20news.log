import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=128, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # First block: linear → layernorm → relu → dropout
        self.block1 = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Residual connection: adapt input if dims don't match
        if input_dim == hidden_dim:
            self.residual = lambda x: x
        else:
            self.residual = nn.Linear(input_dim, hidden_dim)
        
        # Compact two-layer classifier head
        self.head = nn.Sequential(
            nn.Linear(hidden_dim, hidden_dim // 2),
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(hidden_dim // 2, num_classes),
        )

    def forward(self, x):
        # Apply first block and residual
        identity = self.residual(x)
        out = self.block1(x)
        out = out + identity  # residual connection
        
        # Apply classifier head
        logits = self.head(out)
        return logits

# ===== END EVOLVE PGN REGION =====
```
