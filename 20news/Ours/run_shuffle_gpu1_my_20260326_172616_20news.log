        self.classifier_bn = nn.BatchNorm1d(hidden_dim)
        
        # Adaptive bottleneck: remove upper clamp to preserve capacity scaling with hidden_dim
        bottleneck_dim = max(32, hidden_dim // 4)
        self.classifier = nn.Sequential(
            nn.Linear(hidden_dim, bottleneck_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(bottleneck_dim, num_classes),
        )

    def forward(self, x):
        # Compute residual branch: F(x) — no BN on raw input
        h = self.residual_fn[0](x)  # Linear: input_dim → hidden_dim
        h = self.residual_fn[1](h)  # BN on hidden_dim
        h = self.residual_fn[2](h)  # ReLU
        h = self.residual_fn[3](h)  # Dropout
        h = self.residual_fn[4](h)  # Linear: hidden_dim → hidden_dim
        h = self.residual_fn[5](h)  # BN on hidden_dim
        h = self.residual_fn[6](h)  # ReLU
        h = self.residual_fn[7](h)  # Linear: hidden_dim → hidden_dim
        
        # Apply learned skip to original x → x_skip + F(x), both shape (B, hidden_dim)
        skip_out = self.skip(x)
        h = h + skip_out
        
        # Stable pre-classifier normalization
        h = self.classifier_bn(h)
        
        # Classifier head
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
