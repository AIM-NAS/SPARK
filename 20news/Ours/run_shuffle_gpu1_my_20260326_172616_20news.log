import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Residual projection: aligns input dim to hidden_dim
        self.skip = nn.Identity() if input_dim == hidden_dim else nn.Linear(input_dim, hidden_dim)
        
        # Residual MLP sub-block: Linear → BN → ReLU → Dropout → Linear (identity-init second linear)
        # First linear maps input_dim → hidden_dim; second is hidden_dim → hidden_dim with identity init
        self.block1 = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.BatchNorm1d(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(hidden_dim, hidden_dim),
        )
        # Initialize the final linear in block1 with identity weights and zero bias for stable residual updates
        with torch.no_grad():
            self.block1[-1].weight.copy_(torch.eye(hidden_dim))
            self.block1[-1].bias.zero_()
        
        # Post-residual normalization + activation: ReLU before norm improves gradient sign consistency
        self.post_residual_norm = nn.BatchNorm1d(hidden_dim)
        
        # Simplified classifier head: single Linear layer with light dropout only
        # Removes bottleneck and BN — post_residual_norm already stabilizes h; avoids over-parameterization
        self.classifier = nn.Sequential(
            nn.Dropout(0.1),
            nn.Linear(hidden_dim, num_classes),
        )

    def forward(self, x):
        # Apply residual block
        h = self.block1(x)
        # Residual connection
        skip_out = self.skip(x)
        h = h + skip_out
        # Nonlinearity before normalization for stable pre-normalization activations
        h = torch.relu(h)
        # Normalize the summed residual output
        h = self.post_residual_norm(h)
        # Apply simplified classifier
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
