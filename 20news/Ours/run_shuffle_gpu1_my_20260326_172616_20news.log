import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Residual projection: aligns input dim to hidden_dim
        self.skip = nn.Identity() if input_dim == hidden_dim else nn.Linear(input_dim, hidden_dim)
        
        # True residual block: only the *transformative* part (not input projection) is wrapped
        # This ensures skip(x) bypasses all learned transforms in the block
        self.block1 = nn.Sequential(
            nn.Linear(hidden_dim, hidden_dim),
            nn.LayerNorm(hidden_dim, elementwise_affine=True),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Replace BatchNorm with LayerNorm for stable per-sample stats (no running stats, batch-size invariant)
        self.post_residual_norm = nn.LayerNorm(hidden_dim, elementwise_affine=True)
        
        # Lightweight adaptive scaling before final linear — no BN leakage, shape-safe
        self.channel_scale = nn.Parameter(torch.ones(hidden_dim))
        
        # Direct classifier: remove arbitrary bottleneck, apply scaling, then final linear
        self.classifier = nn.Linear(hidden_dim, num_classes)

    def forward(self, x):
        # Project input to hidden_dim for residual path alignment
        h = self.skip(x)
        # Apply true residual block: h = h + block1(h), where block1 starts at hidden_dim
        h = h + self.block1(h)
        # Normalize after residual addition (stable, no batch-stat dependency)
        h = self.post_residual_norm(h)
        # Apply adaptive channel scaling
        h = h * self.channel_scale
        # Final classification
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
