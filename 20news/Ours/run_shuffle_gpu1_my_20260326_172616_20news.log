            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Classifier head: replaced bottleneck with direct projection + lightweight pre-logits dropout
        # Eliminates unnecessary compression and rank collapse; improves gradient flow
        self.classifier_dropout = nn.Dropout(dropout)
        self.classifier = nn.Linear(hidden_dim, num_classes, bias=True)

    def forward(self, x):
        # Compute skip path *before* normalization — preserves raw input magnitude for residual
        skip_out = self.skip(x)
