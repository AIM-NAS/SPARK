import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_proj = nn.Linear(input_dim, hidden_dim)
        self.activation = nn.ReLU()
        self.dropout = nn.Dropout(dropout)
        
        # Learned residual: always project x to hidden_dim for safe addition
        # Eliminates fragile dim-equality check and enables gradient flow through input
        self.res_proj = nn.Linear(input_dim, hidden_dim)
        
        self.ln = nn.LayerNorm(hidden_dim)
        
        # Unified normalization: remove redundant head_ln; use single norm before activation
        # Classifier head: activation → dropout → linear (adds nonlinearity before final layer)
        self.head_dropout = nn.Dropout(dropout)
        self.classifier = nn.Linear(hidden_dim, num_classes)

    def forward(self, x):
        # Project input
        h = self.input_proj(x)
        
        # Learned residual: always add projected input (safe shape, trainable path)
        h = h + self.res_proj(x)
        
        # Normalize → activate → dropout (robust order: norm before activation)
        h = self.ln(h)
        h = self.activation(h)
        h = self.dropout(h)
        
        # Classifier head: apply activation before dropout and classification
        # Recovers representational capacity lost in linear-only head
        h = self.activation(h)
        h = self.head_dropout(h)
        logits = self.classifier(h)
        
        return logits

# ===== END EVOLVE PGN REGION =====
```
