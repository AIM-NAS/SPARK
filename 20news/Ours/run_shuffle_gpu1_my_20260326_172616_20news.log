import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Learnable pre-residual projection: enables gradient-aware alignment
        # Replaces identity-biased skip with trainable x->hidden_dim mapping *inside* residual path
        self.x_proj = nn.Linear(input_dim, hidden_dim)
        
        # Residual block now operates on projected input only — no external skip needed
        self.block1 = nn.Sequential(
            nn.Linear(hidden_dim, hidden_dim),
            nn.LayerNorm(hidden_dim, elementwise_affine=True),
            nn.GELU(),  # Improved gradient behavior & semantic separation for text features
            nn.Dropout(dropout),
        )
        
        # Normalize after residual addition (stable, batch-size invariant)
        self.post_residual_norm = nn.LayerNorm(hidden_dim, elementwise_affine=True)
        
        # Lightweight adaptive scaling before final linear
        self.channel_scale = nn.Parameter(torch.ones(hidden_dim))
        
        # Classifier head with explicit dropout regularization before final linear
        self.dropout_head = nn.Dropout(dropout)
        self.classifier = nn.Linear(hidden_dim, num_classes)

    def forward(self, x):
        # Project input to hidden_dim *once*, used both as residual and block input
        h_proj = self.x_proj(x)
        # Residual: h = h_proj + block1(h_proj)
        h = h_proj + self.block1(h_proj)
        # Normalize
        h = self.post_residual_norm(h)
        # Apply adaptive channel scaling
        h = h * self.channel_scale
        # Regularize scaled features before classification
        h = self.dropout_head(h)
        # Final classification
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
