        )
        # Initialize final linear in block1 with identity weights and zero bias for stable residual updates
        with torch.no_grad():
            self.block1[-1].weight.copy_(torch.eye(hidden_dim))
            self.block1[-1].bias.zero_()

        # Post-residual normalization: LayerNorm (not BatchNorm1d) — shape-safe, batch-size invariant,
        # applied *after* skip addition to stabilize statistics across training dynamics
        self.post_residual_norm = nn.LayerNorm(hidden_dim)

        # Classifier head: fixed dropout — replaced vacuous Dropout1d with correct Dropout
        # Applies element-wise dropout to (B, hidden_dim), enabling meaningful regularization
        self.classifier = nn.Sequential(
            nn.Dropout(0.1),
            nn.Linear(hidden_dim, num_classes),
        )

    def forward(self, x):
        # Apply residual block
        h = self.block1(x)
        # Residual connection
        skip_out = self.skip(x)
        h = h + skip_out
        # Apply LayerNorm *after* residual (true pre-activation for next layer, but post-residual here)
        # Then ReLU — matches pre-activation residual design intent without BN skew
        h = self.post_residual_norm(h)
        h = torch.relu(h)
        # Apply classifier with correct dropout
        logits = self.classifier(h)
        return logits

