import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Input normalization: LayerNorm (batch-invariant, shape-safe, critical for BoW features)
        self.input_norm = nn.LayerNorm(input_dim)
        
        # Pre-activation residual block: skip connection projects input → hidden_dim *before* any nonlinearity
        self.skip = nn.Linear(input_dim, hidden_dim, bias=False)  # bias=False for pure identity scaling
        
        # Block1: Linear → LayerNorm → ReLU → Dropout (pre-activation pattern; stable, shape-agnostic)
        self.block1 = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Residual block: pre-activation style (LayerNorm → ReLU → Linear → Dropout)
        # Ensures gradient continuity and avoids ReLU-zeroing before skip addition
        self.res_block = nn.Sequential(
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Linear(hidden_dim, hidden_dim),
            nn.Dropout(dropout),
        )
        
        # Classifier: direct projection (no bottleneck) — preserves full capacity for 20-way classification
        # Dropout before final linear layer for regularization, no BN needed on logits
        self.classifier = nn.Sequential(
            nn.Dropout(dropout),
            nn.Linear(hidden_dim, num_classes),
        )

    def forward(self, x):
        # Input normalization first
        x = self.input_norm(x)
        
        # Pre-activation residual: compute skip *before* block1 and *before* any nonlinearity
        skip_out = self.skip(x)
        
        # Main branch: block1 (no residual yet)
        h = self.block1(x)
        
        # Apply residual block *then* add skip — now both paths are pre-activated and aligned
        h = self.res_block(h) + skip_out
        
        # Classifier: minimal, direct, shape-safe
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
