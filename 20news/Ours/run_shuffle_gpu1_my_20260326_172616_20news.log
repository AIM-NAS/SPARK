import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # First block: input → hidden with norm + activation + dropout
        self.linear1 = nn.Linear(input_dim, hidden_dim)
        self.norm1 = nn.LayerNorm(hidden_dim)
        self.relu = nn.ReLU()
        self.dropout = nn.Dropout(dropout)
        
        # Residual connection: project input to hidden if dims mismatch
        if input_dim != hidden_dim:
            self.skip_proj = nn.Linear(input_dim, hidden_dim)
        else:
            self.skip_proj = None
        
        # Classifier head: two-layer bottleneck (hidden → hidden//2 → num_classes)
        self.head_linear1 = nn.Linear(hidden_dim, hidden_dim // 2)
        self.head_relu = nn.ReLU()
        self.head_dropout = nn.Dropout(dropout)
        self.head_linear2 = nn.Linear(hidden_dim // 2, num_classes)

    def forward(self, x):
        # First MLP block with normalization and residual
        h = self.linear1(x)
        h = self.norm1(h)
        h = self.relu(h)
        h = self.dropout(h)
        
        # Add skip connection
        if self.skip_proj is not None:
            skip = self.skip_proj(x)
        else:
            skip = x
        h = h + skip  # residual connection
        
        # Classifier head
        h = self.head_linear1(h)
        h = self.head_relu(h)
        h = self.head_dropout(h)
        logits = self.head_linear2(h)
        
        return logits

# ===== END EVOLVE PGN REGION =====
```
