import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.in_ln = nn.LayerNorm(input_dim)
        self.input_proj = nn.Linear(input_dim, hidden_dim)
        self.activation = nn.ReLU()
        self.dropout = nn.Dropout(dropout)
        self.fc2 = nn.Linear(hidden_dim, hidden_dim)
        self.ln = nn.LayerNorm(hidden_dim)
        # Simplified classifier: direct projection from hidden_dim to num_classes
        # Removes redundant bottleneck and nonlinearity for better stability and efficiency
        self.classifier = nn.Linear(hidden_dim, num_classes)
        
        # LayerNormed residual path: normalize input before projection to match normalized domain of h
        self.res_ln = nn.LayerNorm(input_dim)
        self.residual_proj = nn.Linear(input_dim, hidden_dim)

    def forward(self, x):
        # Pre-LN applied to input before projection
        x_norm = self.in_ln(x)
        h = self.input_proj(x_norm)
        
        # Residual: apply LayerNorm to x *before* projection to align with normalized h domain
        residual = self.residual_proj(self.res_ln(x))
        h = h + residual
        
        # Activation and dropout
        h = self.activation(h)
        h = self.dropout(h)
        
        # Second block: Pre-LN before fc2
        h_norm = self.ln(h)
        h = self.fc2(h_norm)
        h = self.activation(h)
        h = self.dropout(h)
        
        # Classifier head: single linear layer (shape-safe, no bottleneck)
        logits = self.classifier(h)
        
        return logits

# ===== END EVOLVE PGN REGION =====
```
