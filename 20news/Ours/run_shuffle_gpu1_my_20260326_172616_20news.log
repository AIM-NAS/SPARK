import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_proj = nn.Linear(input_dim, hidden_dim)
        self.activation = nn.ReLU()
        self.dropout = nn.Dropout(dropout)
        self.fc2 = nn.Linear(hidden_dim, hidden_dim)
        self.ln = nn.LayerNorm(hidden_dim)
        
        # Classifier head: compact two-layer bottleneck with regularization
        self.classifier = nn.Sequential(
            nn.Linear(hidden_dim, 64),
            nn.ReLU(),
            nn.Dropout(0.1),
            nn.Linear(64, num_classes)
        )
        
        # True residual: only if dims match; otherwise skip (no projection)
        self.use_residual = (input_dim == hidden_dim)
        if self.use_residual:
            # Identity shortcut when dims match — no parametric projection needed
            pass  # use x directly as residual
        else:
            # No residual connection when dims mismatch — avoids signal corruption
            # (per LLM2's shape-integrity concern and our self-analysis)
            pass

    def forward(self, x):
        # First layer + activation + dropout
        h = self.input_proj(x)
        h = self.activation(h)
        h = self.dropout(h)
        
        # Residual connection: only when input_dim == hidden_dim (identity)
        if self.use_residual:
            h = h + x  # clean, shape-safe identity residual
        
        # Second hidden layer: LN → activation → dropout (standard order)
        h = self.fc2(h)
        h = self.ln(h)
        h = self.activation(h)
        h = self.dropout(h)
        
        # Classifier head
        logits = self.classifier(h)
        
        return logits

# ===== END EVOLVE PGN REGION =====
```
