import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Pre-residual projection with normalization: aligns input statistics
        # to residual path for stable sparse-feature injection (e.g., TF-IDF)
        if input_dim != hidden_dim:
            self.skip = nn.Sequential(
                nn.LayerNorm(input_dim, elementwise_affine=True),
                nn.Linear(input_dim, hidden_dim),
                nn.ReLU()
            )
        else:
            self.skip = nn.Sequential(
                nn.LayerNorm(input_dim, elementwise_affine=True),
                nn.ReLU()
            )
        
        # Proper 2-layer residual block: LayerNorm → Linear → ReLU → Dropout → Linear → ReLU → Dropout
        # Preserves shape (hidden_dim → hidden_dim), enables full affine expressivity per block
        self.block1 = nn.Sequential(
            nn.LayerNorm(hidden_dim, elementwise_affine=True),
            nn.Linear(hidden_dim, hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(hidden_dim, hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Adaptive channel scaling remains for lightweight feature modulation
        self.channel_scale = nn.Parameter(torch.ones(hidden_dim))
        
        # Classifier head: dropout applied *only* on features before final linear,
        # avoiding stochasticity on logits — improves calibration and stability
        self.classifier = nn.Linear(hidden_dim, num_classes)

    def forward(self, x):
        # Pre-residual path: normalized + projected (if needed) + nonlinear
        h_skip = self.skip(x)
        
        # Residual path: full 2-layer transform
        h = self.block1(h_skip)
        
        # Residual addition: both paths now share normalized, ReLU-activated distributions
        h = h_skip + h
        
        # Apply adaptive scaling
        h = h * self.channel_scale
        
        # Final classification without post-linear dropout (calibration-safe)
        logits = self.classifier(h)
        return logits

