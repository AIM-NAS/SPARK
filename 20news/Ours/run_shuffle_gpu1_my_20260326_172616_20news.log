import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_proj = nn.Linear(input_dim, hidden_dim)
        self.activation = nn.ReLU()
        self.dropout = nn.Dropout(dropout)
        self.classifier = nn.Linear(hidden_dim, num_classes)
        
        # Clean residual projection: always aligns to hidden_dim
        self.residual_proj = nn.Linear(input_dim, hidden_dim) if input_dim != hidden_dim else None
        # LayerNorm after activation (stable for sparse/batch-variant inputs)
        self.ln = nn.LayerNorm(hidden_dim)

    def forward(self, x):
        # Project input
        h = self.input_proj(x)
        
        # Residual connection: identity if dims match, else project
        if self.residual_proj is not None:
            residual = self.residual_proj(x)
        else:
            residual = x  # x.shape == h.shape when input_dim == hidden_dim
        h = h + residual
        
        # Normalize → activate → dropout
        h = self.ln(h)
        h = self.activation(h)
        h = self.dropout(h)
        
        # Direct classification head (no bottleneck)
        logits = self.classifier(h)
        
        return logits

# ===== END EVOLVE PGN REGION =====
```
