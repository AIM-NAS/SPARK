        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Residual projection: learnable linear with orthogonal init when dim mismatch exists
        # Replaces brittle Identity + implicit assumption; enables stable gradient flow
        self.skip = nn.Identity() if input_dim == hidden_dim else nn.Linear(input_dim, hidden_dim, bias=False)
        if input_dim != hidden_dim:
            nn.init.orthogonal_(self.skip.weight)

        # Residual MLP sub-block: pre-activation order (BN → ReLU → Dropout → Linear)
        # First linear maps input_dim → hidden_dim; second is hidden_dim → hidden_dim
        self.block1 = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.BatchNorm1d(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(hidden_dim, hidden_dim),
        )
        # Initialize final linear in block1 with identity weights and zero bias for stable residual updates
        with torch.no_grad():
            self.block1[-1].weight.copy_(torch.eye(hidden_dim))
            self.block1[-1].bias.zero_()

        # Post-residual normalization + activation: now properly pre-activation (BN before ReLU)
        # Fixes gradient sign instability and BN input skew per LLM2 feedback
        self.post_residual_norm = nn.BatchNorm1d(hidden_dim)

        # Classifier head: upgraded regularization — Dropout1d before final Linear
        # Applies channel-wise dropout (structured noise) instead of scalar dropout,
        # better aligned with feature semantics and improves calibration
        self.classifier = nn.Sequential(
            nn.Dropout1d(0.05),
            nn.Linear(hidden_dim, num_classes),
        )

    def forward(self, x):
        # Apply residual block
        h = self.block1(x)
        # Residual connection
        skip_out = self.skip(x)
        h = h + skip_out
        # Now apply BN *before* ReLU (pre-activation residual flow)
        h = self.post_residual_norm(h)
        h = torch.relu(h)
        # Apply classifier with structured dropout
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
