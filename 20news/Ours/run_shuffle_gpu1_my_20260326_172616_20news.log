        self.skip = nn.Identity() if input_dim == hidden_dim else nn.Linear(input_dim, hidden_dim)
        
        # Pre-activation residual block: single Linear → BN → ReLU → Dropout → Linear
        # Skip connection applied *after* first linear+BN+ReLU (pre-activation style)
        # Eliminates redundant projection and improves gradient flow
        self.block1 = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.BatchNorm1d(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(hidden_dim, hidden_dim),
        )
        
        # Replace batch-dependent BatchNorm with shape-stable LayerNorm (no affine params)
        # Preserves distributional stability across batch sizes and domain shifts
        self.post_residual_norm = nn.LayerNorm(hidden_dim, elementwise_affine=False)
        
