        # Post-residual normalization + activation: now properly pre-activation (BN before ReLU)
        # Fixes gradient sign instability and BN input skew per LLM2 feedback
        self.post_residual_norm = nn.BatchNorm1d(hidden_dim)

        # Classifier head: upgraded regularization — Dropout1d before final Linear
        # Applies channel-wise dropout (structured noise) instead of scalar dropout,
        # better aligned with feature semantics and improves calibration
        self.classifier = nn.Sequential(
            nn.Dropout1d(0.05),
            nn.Linear(hidden_dim, num_classes),
        )

    def forward(self, x):
        # Apply residual block
        h = self.block1(x)
        # Residual connection
        skip_out = self.skip(x)
        h = h + skip_out
        # Now apply BN *before* ReLU (pre-activation residual flow)
