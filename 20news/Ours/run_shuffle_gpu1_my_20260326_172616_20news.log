        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Input normalization: LayerNorm (batch-invariant, shape-safe, critical for BoW features)
        self.input_norm = nn.LayerNorm(input_dim)
        
        # Residual projection: pre-activation skip path — projects input to hidden_dim *before* block1
        # Zero-initialized for stable residual learning; bias=False ensures clean zero-init
        self.skip = nn.Linear(input_dim, hidden_dim, bias=False)
        nn.init.zeros_(self.skip.weight)
        
        # Revised block1: single Linear → LayerNorm → ReLU → Dropout
        # Replaced BatchNorm1d with LayerNorm for per-sample stability on sparse BoW inputs
        self.block1 = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Gated residual sub-block: Linear → LayerNorm → ReLU → Dropout → gate projection
        # Uses gating: h_gate = sigmoid(W_g [h; skip_out]) * h_residual → stabilizes update
        # We implement gating via separate linear + sigmoid applied *before* addition
        self.res_proj = nn.Linear(hidden_dim, hidden_dim * 2)  # outputs (h_res, gate)
        self.res_block = nn.Sequential(
            nn.Linear(hidden_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Classifier head: expanded bottleneck (hidden_dim // 2), pre-activation LayerNorm, no dropout in bottleneck
        # Final Linear includes bias (learnable) — restores expressivity lost by aggressive compression
        bottleneck_dim = hidden_dim // 2
        self.classifier = nn.Sequential(
            nn.Linear(hidden_dim, bottleneck_dim),
            nn.LayerNorm(bottleneck_dim),
            nn.ReLU(),
            nn.Linear(bottleneck_dim, num_classes, bias=True),  # explicit bias=True for discriminative power
        )

    def forward(self, x):
        # Input normalization first
        x = self.input_norm(x)
        
        # Pre-activation residual: compute skip *before* block1
        skip_out = self.skip(x)
        
        # Main branch
        h = self.block1(x)
        
        # Apply residual sub-block to h
        h_res = self.res_block(h)
        
        # Gated update: compute gate from concatenated h and skip_out
        gate_input = torch.cat([h, skip_out], dim=-1)  # (B, 2*hidden_dim)
        gate_logits = self.res_proj(gate_input)  # (B, 2*hidden_dim)
        h_res_gate, skip_gate = gate_logits.chunk(2, dim=-1)
        gate = torch.sigmoid(h_res_gate)  # (B, hidden_dim)
        
        # Gated residual update: h = gate * h_res + (1 - gate) * skip_out
        h = gate * h_res + (1 - gate) * skip_out
        
        # Classifier
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
