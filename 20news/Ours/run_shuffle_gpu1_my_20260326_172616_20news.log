import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # First block: input → hidden with norm + activation + dropout
        self.linear1 = nn.Linear(input_dim, hidden_dim)
        self.norm1 = nn.LayerNorm(hidden_dim)
        self.gelu = nn.GELU()
        self.dropout = nn.Dropout(dropout)
        
        # Residual connection: always project to hidden dim for shape safety
        if input_dim != hidden_dim:
            self.skip_proj = nn.Linear(input_dim, hidden_dim)
        else:
            self.skip_proj = nn.Identity()
        
        # Classifier head: two-layer residual block with GELU and scaled skip
        self.head_linear1 = nn.Linear(hidden_dim, hidden_dim)
        self.head_norm = nn.LayerNorm(hidden_dim)
        self.head_gelu = nn.GELU()
        self.head_dropout = nn.Dropout(dropout)
        self.head_linear2 = nn.Linear(hidden_dim, num_classes)
        # Small learnable scale for identity shortcut (initialized to 0.1)
        self.head_skip_scale = nn.Parameter(torch.tensor(0.1))

    def forward(self, x):
        # First MLP block with normalization and residual
        h = self.linear1(x)
        h = self.norm1(h)
        h = self.gelu(h)
        h = self.dropout(h)
        
        # Add skip connection (always shape-matched)
        skip = self.skip_proj(x)
        h = h + skip  # residual connection
        
        # Classifier head: two-layer residual block
        h_head = self.head_linear1(h)
        h_head = self.head_norm(h_head)
        h_head = self.head_gelu(h_head)
        h_head = self.head_dropout(h_head)
        h_head = self.head_linear2(h_head)
        
        # Scaled identity shortcut from h to logits
        logits = h_head + self.head_skip_scale * h[:, :self.num_classes] if h.shape[1] >= self.num_classes else h_head + self.head_skip_scale * h
        
        return logits

# ===== END EVOLVE PGN REGION =====
```
