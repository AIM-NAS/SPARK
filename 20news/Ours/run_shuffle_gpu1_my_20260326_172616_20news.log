import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # First layer + normalization + activation
        self.linear1 = nn.Linear(input_dim, hidden_dim)
        self.bn1 = nn.BatchNorm1d(hidden_dim)
        self.relu = nn.ReLU()
        self.dropout1 = nn.Dropout(dropout)
        
        # Bottleneck classifier head
        self.bottleneck = nn.Sequential(
            nn.Linear(hidden_dim, 64),
            nn.ReLU(),
            nn.Dropout(0.1),
            nn.Linear(64, num_classes)
        )
        
        # Optional residual: only if dimensions match, otherwise project
        if input_dim == hidden_dim:
            self.residual = nn.Identity()
        else:
            self.residual = nn.Linear(input_dim, hidden_dim)

    def forward(self, x):
        # Main path
        h = self.linear1(x)
        h = self.bn1(h)
        h = self.relu(h)
        h = self.dropout1(h)
        
        # Residual connection (input -> hidden_dim space)
        res = self.residual(x)
        h = h + res  # stabilized skip
        
        # Classifier head
        logits = self.bottleneck(h)
        return logits

# ===== END EVOLVE PGN REGION =====
