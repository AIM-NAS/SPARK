            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(hidden_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(hidden_dim, hidden_dim),
        )
        
        # Projection from input to residual block dim (input_dim → hidden_dim)
        # Applied *before* the residual block — enables true pre-activation semantics
        self.input_proj = nn.Linear(input_dim, hidden_dim)
        
        # Skip connection: identity projection only if dims match; otherwise learned linear
        if input_dim == hidden_dim:
            self.skip = nn.Identity()
        else:
            self.skip = nn.Linear(input_dim, hidden_dim, bias=False)
            nn.init.eye_(self.skip.weight)
        
        # Classifier head: direct mapping from stabilized residual output → logits
        # No bottleneck reduction — preserves signal for 20-way classification
        # Dropout moved *before* final Linear (i.e., on bottleneck features), not after logits
        self.classifier = nn.Sequential(
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Dropout(0.1),
            nn.Linear(hidden_dim, num_classes),
        )

    def forward(self, x):
        # Input normalization first
        x = self.input_norm(x)
        
        # Project input to hidden_dim *before* residual block (pre-activation setup)
        h = self.input_proj(x)
        
        # Skip connection applied to pre-activation input (x), not normalized h
        skip_out = self.skip(x)
        
        # Apply residual block to h (which is already projected)
        # Block outputs raw transform; skip is added *after* block, before final nonlinearity
        h = self.res_block(h)
        
        # Stable residual update: skip_out + h, then no extra ReLU (block ends with Linear,
        # and classifier begins with LayerNorm+ReLU — avoids double nonlinearity)
        h = h + skip_out
        
        # Classifier: pre-activation norm → ReLU → dropout → logits
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
