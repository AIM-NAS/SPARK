import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # First layer + normalization + activation
        self.linear1 = nn.Linear(input_dim, hidden_dim)
        self.ln1 = nn.LayerNorm(hidden_dim)
        self.relu = nn.ReLU()
        self.dropout1 = nn.Dropout(dropout)
        
        # Residual projection (input -> hidden_dim space)
        if input_dim == hidden_dim:
            self.residual = nn.Identity()
        else:
            self.residual = nn.Linear(input_dim, hidden_dim)

        # Two-layer classifier head: wider bottleneck with proper nonlinearity
        self.classifier = nn.Sequential(
            nn.Linear(hidden_dim, 128),
            nn.ReLU(),
            nn.Dropout(0.1),
            nn.Linear(128, num_classes)
        )

    def forward(self, x):
        # Main path: linear → layernorm → relu → dropout
        h = self.linear1(x)
        h = self.ln1(h)
        h = self.relu(h)
        h = self.dropout1(h)
        
        # Residual connection *after* normalization and activation (aligned distribution)
        res = self.residual(x)
        h = h + res  # stabilized skip
        
        # Classifier head
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
```
