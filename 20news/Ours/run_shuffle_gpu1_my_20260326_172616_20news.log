        self.num_classes = num_classes
        
        # Input normalization: LayerNorm with learnable affine for better adaptability
        # (elementwise_affine=True improves expressivity without harming shape-safety)
        self.input_norm = nn.LayerNorm(input_dim, elementwise_affine=True)
        
