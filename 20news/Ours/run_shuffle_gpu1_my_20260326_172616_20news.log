import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Input normalization: LayerNorm (batch-invariant, shape-safe, critical for BoW features)
        self.input_norm = nn.LayerNorm(input_dim)
        
        # Residual projection: projects input to hidden_dim *before* block1
        # Zero-initialized for stable residual learning; bias=False ensures clean zero-init
        self.skip = nn.Linear(input_dim, hidden_dim, bias=False)
        nn.init.zeros_(self.skip.weight)
        
        # Block1: pre-norm — LayerNorm(input_dim) → Linear(input_dim→hidden_dim) → ReLU → Dropout
        # Uses input_dim norm (not hidden_dim) to match x shape before projection
        self.block1_norm = nn.LayerNorm(input_dim)
        self.block1 = nn.Linear(input_dim, hidden_dim)
        self.block1_act = nn.ReLU()
        self.block1_drop = nn.Dropout(dropout)
        
        # GLU-based residual refinement: only applied *after* block1 output is guaranteed hidden_dim
        # Projection: hidden_dim → 2*hidden_dim, then GLU → hidden_dim
        self.glu_linear = nn.Linear(hidden_dim, hidden_dim * 2)
        self.glu_proj = nn.GLU(dim=-1)
        
        # Residual sub-block: pre-norm style, with its *own* LayerNorm over hidden_dim
        self.res_block_norm = nn.LayerNorm(hidden_dim)
        self.res_block = nn.Sequential(
            nn.Linear(hidden_dim, hidden_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
        )
        
        # Classifier head: simplified and shape-safe
        # Removed redundant inner LayerNorm; kept dropout + bias-enabled final linear
        bottleneck_dim = max(32, int(hidden_dim // 1.5))  # floor-guarded to avoid tiny dims
        self.classifier = nn.Sequential(
            nn.Linear(hidden_dim, bottleneck_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(bottleneck_dim, num_classes, bias=True),
        )

    def forward(self, x):
        # Input normalization first
        x = self.input_norm(x)
        
        # Pre-activation residual: compute skip *before* block1
        skip_out = self.skip(x)
        
        # Main branch: apply norm to x (shape B, input_dim), then project
        h = self.block1_norm(x)
        h = self.block1(h)
        h = self.block1_act(h)
        h = self.block1_drop(h)
        
        # GLU refinement: now h is guaranteed (B, hidden_dim)
        projected = self.glu_linear(h)  # (B, 2*hidden_dim)
        gated = self.glu_proj(projected)  # (B, hidden_dim)
        candidate = self.res_block_norm(gated)
        candidate = self.res_block(candidate)
        
        # Residual update
        h = skip_out + candidate
        
        # Classifier: no inner LayerNorm, bias enabled, shape-safe
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
```
