import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=256, dropout=0.2):
        super().__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Pre-activation residual block: identity-aligned skip + clean F(x)
        # Skip is now input_dim → hidden_dim *only if needed*, but applied *before* block
        # to enable true x + F(x) with F(x) = BN→ReLU→Linear→Dropout→BN→ReLU→Linear
        self.skip = nn.Linear(input_dim, hidden_dim) if input_dim != hidden_dim else nn.Identity()
        if input_dim != hidden_dim:
            nn.init.zeros_(self.skip.weight)
            if self.skip.bias is not None:
                nn.init.zeros_(self.skip.bias)
        
        # Clean pre-activation residual function F(x):
        # Input x → BN → ReLU → Linear → Dropout → BN → ReLU → Linear → output same dim
        self.residual_fn = nn.Sequential(
            nn.BatchNorm1d(input_dim),
            nn.ReLU(),
            nn.Linear(input_dim, hidden_dim),
            nn.Dropout(dropout),
            nn.BatchNorm1d(hidden_dim),
            nn.ReLU(),
            nn.Linear(hidden_dim, hidden_dim),
        )
        
        # Single stabilizing BN before classifier — removed redundant post_residual_bn
        self.classifier_bn = nn.BatchNorm1d(hidden_dim)
        
        # Adaptive bottleneck: hidden_dim // 4, clamped to [32, 128], no BN (avoids instability)
        bottleneck_dim = max(32, min(128, hidden_dim // 4))
        self.classifier = nn.Sequential(
            nn.Linear(hidden_dim, bottleneck_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(bottleneck_dim, num_classes),
        )

    def forward(self, x):
        # Compute residual branch: F(x)
        h = self.residual_fn[0](x)  # BN on input
        h = self.residual_fn[1](h)  # ReLU
        h = self.residual_fn[2](h)  # Linear: input_dim → hidden_dim
        h = self.residual_fn[3](h)  # Dropout
        h = self.residual_fn[4](h)  # BN on intermediate
        h = self.residual_fn[5](h)  # ReLU
        h = self.residual_fn[6](h)  # Linear: hidden_dim → hidden_dim
        
        # Apply skip *to original x*, then add: x_skip + F(x) → true pre-activation residual
        skip_out = self.skip(x)
        h = h + skip_out
        
        # Single batch norm before classifier — stable, minimal, shape-safe
        h = self.classifier_bn(h)
        
        # Classifier head without bottleneck BN (avoids small-dim instability)
        logits = self.classifier(h)
        return logits

# ===== END EVOLVE PGN REGION =====
