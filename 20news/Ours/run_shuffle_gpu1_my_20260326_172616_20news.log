import torch
import torch.nn as nn

# ===== BEGIN EVOLVE PGN REGION =====
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, num_classes, hidden_dim=128, dropout=0.2):
        super().__init__()
        self.input_proj = nn.Linear(input_dim, hidden_dim)
        self.norm1 = nn.LayerNorm(hidden_dim)
        # Bottleneck: hidden_dim → hidden_dim//2 → hidden_dim
        self.bottleneck_down = nn.Linear(hidden_dim, hidden_dim // 2)
        self.bottleneck_up = nn.Linear(hidden_dim // 2, hidden_dim)
        self.norm2 = nn.LayerNorm(hidden_dim)
        self.dropout = nn.Dropout(dropout)
        self.classifier = nn.Linear(hidden_dim, num_classes)
        self.classifier_bias = nn.Parameter(torch.zeros(num_classes))
        self.activation = nn.ReLU()

    def forward(self, x):
        # Post-norm activation: project → norm → activate
        h = self.input_proj(x)
        h = self.activation(self.norm1(h))
        
        # Bottleneck residual block: h → down → act → up → norm → act → dropout → +h
        h_residual = h
        h = self.bottleneck_down(h)
        h = self.activation(h)
        h = self.bottleneck_up(h)
        h = self.activation(self.norm2(h))
        h = self.dropout(h)
        h = h + h_residual
        
        # Classifier with explicit bias to stabilize dropout-induced mean shift
        logits = self.classifier(h) + self.classifier_bias
        return logits

# ===== END EVOLVE PGN REGION =====
```
