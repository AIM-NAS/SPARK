        bottleneck_dim = hidden_dim // 4
        self.classifier = nn.Sequential(
            nn.Linear(hidden_dim, bottleneck_dim),
            nn.BatchNorm1d(bottleneck_dim),  # ✅ Stable BN on low-dim features
            nn.ReLU(),
            nn.Dropout(0.1),
            nn.Linear(bottleneck_dim, num_classes),
        )

    def forward(self, x):
        # Normalize input
        x = self.input_norm(x)
        # Residual path: scaled projection
